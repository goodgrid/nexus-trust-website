# Copy to .env and fill in. .env is gitignored.

# Umami analytics (public, client-side values baked in at build time).
VITE_UMAMI_HOST=https://cloud.umami.is
VITE_UMAMI_WEBSITE_ID=

# Contact form -> Brevo (server-side runtime config).
# BREVO_API_KEY is secret. CONTACT_FROM must be a verified sender in Brevo.
BREVO_API_KEY=
CONTACT_TO=hi@nexustrust.eu
CONTACT_FROM=no-reply@nexustrust.eu
CONTACT_FROM_NAME=Nexus Trust website

# Server port (defaults to 3000 locally, 8080 in the container).
# PORT=3000
